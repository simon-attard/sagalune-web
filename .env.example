# Sagalune landing page — env vars
# These are set in the Vercel dashboard (Project Settings → Environment Variables),
# NOT committed to the repo. This file is for documentation only.

# Your Supabase project URL (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase service_role key (Settings → API → service_role secret)
# WARNING: this key bypasses Row Level Security. Never expose it in the browser.
# It lives in Vercel env vars and is only used server-side by api/waitlist.js.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...
